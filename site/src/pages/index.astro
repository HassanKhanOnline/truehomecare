---
// Homepage — mirrored from the live True Homecare theme (Understrap) for exact design fidelity.
import body from '../mirror/home-body.html?raw';

const css = [
  '/wp-content/plugins/metronet-profile-picture/dist/blocks.style.build.css',
  '/wp-content/cache/wpfc-minified/2ni3g6i5/1x9wk.css',
  '/wp-content/themes/understrap-child/css/child-theme.min.css',
  '/wp-content/themes/understrap-child/css/skin/default-skin.css',
  '/wp-content/themes/understrap-child/css/slick.css',
  '/wp-content/themes/understrap-child/css/media-query.css',
  '/wp-content/themes/understrap-child/css/advanced-style-css-final.css',
  '/wp-content/cache/wpfc-minified/95ewxax8/1x9wk.css',
  '/wp-content/plugins/gravityforms/assets/css/dist/basic.min.css',
  '/wp-content/plugins/gravityforms/assets/css/dist/theme.min.css',
  '/wp-content/cache/wpfc-minified/e734x7hm/1x9xw.css',
];
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>True Homecare — Reliable, Trustworthy In-Home Care</title>
    <meta
      name="description"
      content="True Homecare provides compassionate, personalised in-home care across Stockport, Cheshire East and the North West. CQC registered. Call 0161 428 1989."
    />
    {css.map((href) => <link rel="stylesheet" href={href} />)}
    <link rel="stylesheet" href="/css/overrides.css" />
  </head>
  <body class="home page wp-theme-understrap wp-child-theme-understrap-child understrap-has-sidebar">
    <Fragment set:html={body} />
    <script is:inline src="/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/js/swiper-bundle.min.js"></script>
    <script is:inline src="/js/site-interactions.js"></script>
  </body>
</html>
