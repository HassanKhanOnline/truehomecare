---
import Layout from '../layouts/Layout.astro';
import LeadForm from '../components/LeadForm.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Accordion from '../components/Accordion.astro';
import Trustindex from '../components/Trustindex.astro';
import { site, services, moreServices, homeFaqs, trustindex } from '../data/site';

const pillars = [
  { title: 'Committed to Comfort and Quality', body: 'Your comfort is our priority. From the moment you reach out, our dedicated team ensures that your care plan reflects the high standards of quality you deserve. We deliver care that aligns with your lifestyle, allowing you to thrive at home.' },
  { title: 'Where Expertise Meets Compassion', body: 'Each member of our team brings a wealth of experience, training and a genuine passion for providing exceptional care. We’re here to help you live comfortably and independently, with the support you need, when you need it.' },
  { title: 'Care as Unique as You Are', body: 'Every person is different, and so are their care needs. That’s why we offer flexible, bespoke care solutions that cater to your specific requirements. Whether it’s companionship, specialist care or assistance with daily tasks, we tailor our services to support your health, happiness and wellbeing at home.' },
];
---
<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <h1>Reliable, Trustworthy —<br />True Homecare</h1>
        <p>
          Specialised in providing care to clients in their own homes. Our team of experienced and
          compassionate carers are dedicated to ensuring the highest quality of life for our clients,
          allowing them to maintain their independence in the comfort of their own homes.
        </p>
        <div class="hero__badge"><Trustindex id={trustindex.heroBadge} /></div>
        <a href={site.phoneHref} class="hero__phone">
          <span class="hero__phone-ico">📞</span>
          <span><strong>{site.phone}</strong><em>{site.hoursNote}</em></span>
        </a>
      </div>
      <div class="hero__form"><LeadForm /></div>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="section">
    <div class="container">
      <div class="heading-center">
        <h2>Compassionate Care, Tailored for You</h2>
        <p>At True Homecare, we believe in offering personalised care that respects your unique needs. Our compassionate team works closely with you to develop a care plan that supports your independence and enhances your wellbeing.</p>
        <div class="rule"></div>
      </div>
      <div class="grid grid-3">
        {pillars.map((p) => (
          <div class="pillar">
            <div class="pillar__icon">✚</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GREEN BAND -->
  <section class="section section--green band">
    <div class="container">
      <h2>Personalised Care, Tailored for You</h2>
      <p>At True Homecare, we’re dedicated to helping you stay in the comfort of your own home. Our services are fully customised to meet the unique needs of each client, ensuring the best possible care. We carefully match each client with a certified, experienced care provider who offers flexible and professional care, designed to enhance your independence and wellbeing.</p>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section section--tint">
    <div class="container">
      <div class="heading-center">
        <h2>What True Homecare clients say about their care experience.</h2>
      </div>
      <Trustindex id={trustindex.reviewsWidget} />
    </div>
  </section>

  <!-- SERVICES (green) -->
  <section class="section section--green">
    <div class="container">
      <div class="services-head">
        <div>
          <h2>Our Services</h2>
          <p>We have tailor-made packages to suit the unique needs of all our clients. True Homecare are a family-run independent care company managing a staff of trained, experienced carers.</p>
        </div>
        <a href="/services/" class="btn btn--outline">View All Services</a>
      </div>
      <div class="grid grid-3">
        {services.slice(6, 9).map((s) => <ServiceCard {...s} light />)}
      </div>
    </div>
  </section>

  <!-- DISCOVER SERVICES (deep green) -->
  <section class="section section--deep">
    <div class="container">
      <div class="heading-center" style="text-align:left; max-width:none;">
        <h2 style="color:#fff;">Discover Quality Care Services for Your Loved Ones</h2>
        <p>The right care is right here. Explore our comprehensive range of services tailored to meet the unique needs of your family.</p>
      </div>
      <div class="grid grid-3">
        {services.slice(0, 6).map((s) => <ServiceCard {...s} light />)}
      </div>
    </div>
  </section>

  <!-- EVEN MORE OPTIONS -->
  <section class="section">
    <div class="container">
      <div class="heading-center"><h2>Even more options.</h2><div class="rule"></div></div>
      <div class="grid grid-2" style="max-width:860px;margin:0 auto;">
        {moreServices.map((s) => (
          <a href={`/services/${s.slug}/`} class="more-card">
            <h3>{s.title}</h3>
            <p>{s.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EXCELLENCE BAND -->
  <section class="section section--tint">
    <div class="container excellence">
      <div class="excellence__img" aria-hidden="true"></div>
      <div>
        <h2>Delivering Excellence in Care, Every Day</h2>
        <p>Committed to delivering compassionate, high-quality care, we’re proud to have achieved a “Good” rating from the Care Quality Commission. Your wellbeing is our top priority, and we strive for excellence in everything we do.</p>
        <a href={site.phoneHref} class="btn btn--ghost">{site.phone}</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="heading-center"><h2>True Homecare FAQ</h2><div class="rule"></div></div>
      <Accordion items={homeFaqs} />
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero { background: var(--green); color: #fff; position: relative; }
  .hero__inner { display: grid; grid-template-columns: 1.3fr 0.9fr; gap: 48px; align-items: center; padding: 64px 20px; }
  .hero__copy h1 { color: #fff; }
  .hero__copy p { color: rgba(255,255,255,0.9); max-width: 520px; }
  .hero__badge { background: #fff; border-radius: 8px; display: inline-block; padding: 6px 10px; margin: 8px 0 20px; }
  .hero__phone { display: inline-flex; align-items: center; gap: 12px; color: #fff; }
  .hero__phone-ico { width: 44px; height: 44px; border-radius: 50%; background: var(--orange); display: grid; place-items: center; font-size: 1.1rem; }
  .hero__phone strong { display: block; font-size: 1.2rem; }
  .hero__phone em { font-style: normal; font-size: 0.8rem; opacity: 0.85; }
  .hero__form { display: flex; justify-content: flex-end; }

  .pillar { text-align: center; padding: 0 12px; }
  .pillar__icon { width: 62px; height: 62px; border-radius: 50%; border: 2px solid var(--green-logo); color: var(--green-logo); display: grid; place-items: center; font-size: 1.5rem; margin: 0 auto 18px; }
  .pillar h3 { font-size: 1.1rem; }

  .band { text-align: center; }
  .band p { max-width: 820px; margin: 0 auto; }

  .services-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 40px; }
  .services-head p { max-width: 640px; margin: 0; }

  .more-card { display: block; color: inherit; padding-bottom: 16px; border-bottom: 2px solid var(--green-logo); }
  .more-card h3 { color: var(--ink); }
  .more-card:hover h3 { color: var(--orange); }

  .excellence { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
  .excellence__img { aspect-ratio: 4/3; border-radius: 10px; background: linear-gradient(135deg, #cfe1d6, #b2cebd); }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__form { justify-content: flex-start; }
    .services-head { flex-direction: column; align-items: flex-start; }
    .excellence { grid-template-columns: 1fr; }
  }
</style>
